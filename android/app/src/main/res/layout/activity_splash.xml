<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/muton_screen_bg">

    <FrameLayout
        android:id="@+id/brandStage"
        android:layout_width="wrap_content"
        android:layout_height="150dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/brandRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:gravity="center"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/muStage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingStart="0dp"
                android:translationX="1dp">

                <TextView
                    android:id="@+id/txtSplashMuBase"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:includeFontPadding="false"
                    android:letterSpacing="-0.02"
                    android:text="@string/splash_mu"
                    android:textColor="@color/muton_text"
                    android:textSize="38sp" />

                <ImageView
                    android:id="@+id/imgSplashLogo"
                    android:layout_width="60dp"
                    android:layout_height="47dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:alpha="0"
                    android:scaleType="fitXY"
                    android:translationX="0dp"
                    android:translationY="15dp"
                    android:src="@drawable/bg_logo_mark" />

                <TextView
                    android:id="@+id/txtSplashMuOverlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0"
                    android:fontFamily="sans-serif-black"
                    android:includeFontPadding="false"
                    android:letterSpacing="-0.02"
                    android:text="@string/splash_mu"
                    android:textColor="@android:color/white"
                    android:textSize="38sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/txtSplashTon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="-1dp"
                android:fontFamily="sans-serif-black"
                android:includeFontPadding="false"
                android:letterSpacing="-0.02"
                android:text="@string/splash_ton"
                android:textColor="@color/muton_text"
                android:textSize="38sp" />
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
