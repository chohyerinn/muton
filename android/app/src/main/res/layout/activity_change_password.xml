<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/muton_screen_bg"
    android:paddingHorizontal="24dp"
    android:paddingTop="34dp">

    <LinearLayout
        android:id="@+id/backButton"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_back_button"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&lt;"
            android:textColor="@color/muton_text"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="146dp"
        android:text="@string/settings_change_password_title"
        android:textColor="@color/muton_text"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/formWrap"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="42dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtTitle">

        <EditText
            android:id="@+id/inputCurrentPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_outline_pill"
            android:hint="@string/settings_current_password"
            android:inputType="textPassword"
            android:minHeight="0dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="9dp"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/inputNewPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_outline_pill"
            android:hint="@string/settings_new_password"
            android:inputType="textPassword"
            android:minHeight="0dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="9dp"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_outline_pill"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="9dp">

            <EditText
                android:id="@+id/inputConfirmPassword"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/settings_confirm_password"
                android:inputType="textPassword"
                android:minHeight="0dp"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/btnConfirmVisibility"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:clickable="true"
                android:contentDescription="@null"
                android:focusable="true"
                android:src="@android:drawable/ic_menu_view"
                android:tint="@color/muton_text" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtPasswordMismatch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="5dp"
            android:text="@string/signup_password_mismatch"
            android:textColor="@android:color/holo_red_light"
            android:textSize="11sp"
            android:visibility="gone" />
    </LinearLayout>

    <Button
        android:id="@+id/btnChange"
        android:layout_width="112dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
                android:backgroundTint="@color/muton_surface_elevated"
        android:text="@string/settings_change_action"
        android:textColor="@color/muton_muted"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/formWrap" />

</androidx.constraintlayout.widget.ConstraintLayout>
