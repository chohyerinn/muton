<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/muton_screen_bg">

    <View
        android:id="@+id/logoMark"
        android:layout_width="94dp"
        android:layout_height="70dp"
        android:layout_marginTop="196dp"
        android:background="@drawable/bg_logo_mark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/formWrap"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="48dp"
        android:layout_marginTop="50dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logoMark">

        <EditText
            android:id="@+id/inputEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_outline_pill"
            android:hint="ID"
            android:inputType="text"
            android:minHeight="0dp"
            android:paddingHorizontal="18dp"
            android:paddingVertical="10dp"
            android:textColor="@color/muton_text"
            android:textColorHint="@color/muton_muted"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_outline_pill"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="18dp"
            android:paddingVertical="10dp">

            <EditText
                android:id="@+id/inputPassword"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="password"
                android:inputType="textPassword"
                android:minHeight="0dp"
                android:textColor="@color/muton_text"
                android:textColorHint="@color/muton_muted"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/btnPasswordVisibility"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:clickable="true"
                android:contentDescription="@null"
                android:focusable="true"
                android:src="@android:drawable/ic_menu_view"
                android:tint="@color/muton_text" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtGoSignUp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_small_pill_outline"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp"
            android:text="@string/login_secondary"
            android:textColor="@color/muton_primary"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="112dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="28dp"
            android:backgroundTint="@color/muton_surface_elevated"
            android:text="log in"
            android:textColor="@color/muton_muted"
            android:textSize="13sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
