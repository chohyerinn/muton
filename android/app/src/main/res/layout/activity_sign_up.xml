<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/muton_screen_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <View
            android:id="@+id/logoMark"
            android:layout_width="94dp"
            android:layout_height="70dp"
            android:layout_marginTop="140dp"
            android:background="@drawable/bg_logo_mark"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/formWrap"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="44dp"
            android:layout_marginTop="50dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/logoMark">

            <EditText
                android:id="@+id/inputName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_outline_pill"
                android:hint="ID"
                android:minHeight="0dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="9dp"
                android:textColor="@color/muton_text"
                android:textColorHint="@color/muton_muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtNicknameDuplicate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="5dp"
                android:text="@string/signup_nickname_taken"
                android:textColor="@color/muton_primary"
                android:textSize="11sp"
                android:visibility="gone" />

            <EditText
                android:id="@+id/inputPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_outline_pill"
                android:hint="password"
                android:inputType="textPassword"
                android:minHeight="0dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="9dp"
                android:textColor="@color/muton_text"
                android:textColorHint="@color/muton_muted"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_outline_pill"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="9dp">

                <EditText
                    android:id="@+id/inputPasswordConfirm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="check password"
                    android:inputType="textPassword"
                    android:minHeight="0dp"
                    android:textColor="@color/muton_text"
                    android:textColorHint="@color/muton_muted"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/btnPasswordConfirmVisibility"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:clickable="true"
                    android:contentDescription="@null"
                    android:focusable="true"
                    android:src="@android:drawable/ic_menu_view"
                    android:tint="@color/muton_text" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtPasswordMismatch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="5dp"
                android:text="@string/signup_password_mismatch"
                android:textColor="@android:color/holo_red_light"
                android:textSize="11sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/termsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgTermsArrow"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_terms_triangle"
                    android:tint="@color/muton_muted" />

                <TextView
                    android:id="@+id/txtTermsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/terms_all"
                    android:textColor="@color/muton_muted"
                    android:textSize="15sp" />

                <CheckBox
                    android:id="@+id/switchAllTerms"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_permission_circle"
                    android:button="@null" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/termsDetailWrap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/terms_mic"
                        android:textColor="@color/muton_muted"
                        android:textSize="14sp" />

                    <CheckBox
                        android:id="@+id/switchMicPermission"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="14dp"
                        android:background="@drawable/bg_permission_circle"
                        android:button="@null" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/terms_camera"
                        android:textColor="@color/muton_muted"
                        android:textSize="14sp" />

                    <CheckBox
                        android:id="@+id/switchCameraPermission"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="14dp"
                        android:background="@drawable/bg_permission_circle"
                        android:button="@null" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnComplete"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="28dp"
                android:backgroundTint="@color/muton_surface_elevated"
                android:enabled="false"
                android:text="@string/signup_complete"
                android:textColor="@color/muton_muted"
                android:textSize="13sp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/voiceOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginHorizontal="42dp"
            android:background="@drawable/bg_overlay_card"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="22dp"
            android:paddingBottom="24dp">

            <Chronometer
                android:id="@+id/txtOverlayTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/record_timer"
                android:textColor="@color/muton_text"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtRecordTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:text="@string/record_title"
                android:textColor="@color/muton_text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtRecordSample"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/record_sample"
                android:textColor="@color/muton_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/btnMicRecord"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_mic_button"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imgMicIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_voice_mic" />
            </LinearLayout>

            <Button
                android:id="@+id/btnRecordAction"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:alpha="0"
                android:clickable="false"
                android:focusable="false"
                android:text="@string/record_start" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
